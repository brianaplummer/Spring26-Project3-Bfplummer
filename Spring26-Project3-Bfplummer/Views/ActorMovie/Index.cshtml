@model IEnumerable<Spring26_Project3_Bfplummer.Models.ActorMovie>

@{
    ViewData["Title"] = "Actor Movie Relationships";
}

<h1>Actor Movie Relationships</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Relationship</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Actor</th>
            <th>Movie</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Actor?.Name</td>
                <td>@item.Movie?.Title</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
