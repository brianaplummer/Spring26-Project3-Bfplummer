@model Spring26_Project3_Bfplummer.Models.Actor

@{
    ViewData["Title"] = "Edit Actor";
}

<h1>Edit Actor</h1>

<form asp-action="Edit" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-2">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="Age" class="control-label"></label>
        <input asp-for="Age" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label asp-for="Gender" class="control-label"></label>
        <input asp-for="Gender" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label asp-for="IMDB_Link" class="control-label"></label>
        <input asp-for="IMDB_Link" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label asp-for="PhotoFile" class="control-label"></label>
        <input asp-for="PhotoFile" type="file" class="form-control" />
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Save" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
