@model Spring26_Project3_Bfplummer.Models.ViewModels.ActorDetailsViewModel

@{
    ViewData["Title"] = "Actor Details";
}

<h1>@Model.Actor?.Name</h1>

@if (Model.Actor != null)
{
    <p><strong>Age:</strong> @Model.Actor.Age</p>
    <p><strong>Gender:</strong> @Model.Actor.Gender</p>
    <p>
        <strong>IMDB:</strong>
        <a href="@Model.Actor.IMDB_Link" target="_blank">View IMDB</a>
    </p>

    <img asp-controller="Actor" asp-action="Photo" asp-route-id="@Model.Actor.Id" width="250" class="mb-3" />
}

<h3>Movies with this Actor</h3>
<ul>
    @foreach (var movie in Model.Movies)
    {
        <li>@movie.Title</li>
    }
</ul>

<h3>Overall Sentiment: @Model.OverAllActorSentiment.ToString("0.000")</h3>

<table class="table">
    <thead>
        <tr>
            <th>AI Tweet</th>
            <th>Sentiment</th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < Model.Tweets.Length; i++)
        {
            <tr>
                <td>@Model.Tweets[i]</td>
                <td>@Model.TweetSentiments[i].ToString("0.000")</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Back to List</a>
